# Aether 3D Weather API Configuration
# Rename this file to .env and input your API keys below.

# OpenWeatherMap API Key (Get a free key from https://openweathermap.org/api)
WEATHER_API_KEY="your_openweathermap_api_key_here"

# Groq API Key (Get a key from https://console.groq.com/)
GROQ_API_KEY="your_groq_api_key_here"
